{
  "name": "dashscope-model-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:* --banner:js='import{createRequire}from\"node:module\";const require=createRequire(import.meta.url);'",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "release:prepare": "pnpm build && node scripts/prepare-release.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "dotenv": "^16.5.0",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.10.0"
}
